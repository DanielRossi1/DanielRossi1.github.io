<div class="repo p-2 text-center">
  <a href="https://github.com/{{ include.username }}">
    <span class="d-none d-sm-none d-md-block">
      <img
        class="only-light"
        alt="{{ include.username }}"
        src="https://github-profile-trophy.vercel.app/?username={{ include.username }}&theme={{ site.repo_trophies.theme_light }}&locale={{ site.lang }}&margin-w=15&margin-h=15&no-bg=true&rank=-C&column=6"
        onerror="this.onerror=null; this.parentElement.parentElement.innerHTML='<div style=\'padding:20px;border:1px solid #e1e4e8;border-radius:6px\'><img src=\'https://github.com/{{ include.username }}.png\' style=\'width:60px;height:60px;border-radius:50%\'/><br/><strong>{{ include.username }}</strong><br/><small>GitHub Trophies unavailable</small></div>';"
      >
      <img
        class="only-dark"
        alt="{{ include.username }}"
        src="https://github-profile-trophy.vercel.app/?username={{ include.username }}&theme={{ site.repo_trophies.theme_dark }}&locale={{ site.lang }}&margin-w=15&margin-h=15&no-bg=true&rank=-C&column=6"
        onerror="this.onerror=null; this.parentElement.parentElement.innerHTML='<div style=\'padding:20px;border:1px solid #30363d;border-radius:6px\'><img src=\'https://github.com/{{ include.username }}.png\' style=\'width:60px;height:60px;border-radius:50%\'/><br/><strong style=\'color:#c9d1d9\'>{{ include.username }}</strong><br/><small style=\'color:#8b949e\'>GitHub Trophies unavailable</small></div>';"
      >
    </span>

    <span class="d-none d-sm-block d-md-none">
      <img
        class="only-light"
